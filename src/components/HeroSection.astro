---
---

<section class="relative min-h-screen flex items-end overflow-hidden">
  <!-- Background image -->
  <div class="absolute inset-0">
    <img
      src="/images/hero-dojo.jpg"
      alt="Traditional Japanese dojo with warm natural light"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-primary/60"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 mx-auto max-w-6xl w-full px-6 pb-20 pt-40 md:pb-32 md:pt-48">
    <div class="max-w-2xl">
      <p class="text-sm tracking-[0.4em] uppercase text-primary-foreground/70 mb-4">
        Personal Martial Art Lessons
      </p>
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold leading-tight text-primary-foreground text-balance">
        The Art of Body & Mind
      </h1>
      <p class="mt-6 text-lg md:text-xl leading-relaxed text-primary-foreground/80 max-w-lg">
        Taiso is a Japanese discipline of body conditioning rooted in centuries of martial arts tradition. Discover harmony through movement.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4">
        <a
          href="#contact"
          class="inline-flex items-center justify-center rounded-sm bg-background px-8 py-3.5 text-sm font-medium text-foreground transition-colors hover:bg-background/90"
        >
          Begin Your Practice
        </a>
        <a
          href="#philosophy"
          class="inline-flex items-center justify-center rounded-sm border border-primary-foreground/30 px-8 py-3.5 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary-foreground/10"
        >
          Learn More
        </a>
      </div>
    </div>

    <!-- Decorative Japanese character -->
    <div class="absolute right-6 md:right-12 bottom-16 md:bottom-24 opacity-10 pointer-events-none select-none">
      <span class="text-[8rem] md:text-[14rem] font-bold text-primary-foreground leading-none">
        体
      </span>
    </div>
  </div>
</section>
