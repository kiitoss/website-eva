---
const news = [
  {
    id: "event",
    category: "Évènement",
    date: "15 mars 2026",
    title: "Cours d'été",
    description:
      "Une journée complète d'immersion dans les principes traditionnels du mouvement Taïso. Respiration, conditionnement physique et travail en binôme - ouvert à tous les niveaux. Les places sont strictement limitées.",
  },
  {
    id: "announcement",
    category: "Annonce",
    date: "10 février 2026",
    title: "Nouveau cours du soir",
    description:
      "En raison d'une forte demande, deux nouveaux créneaux horaires sont ouverts les mardis et jeudis à partir du 1er mars. Inscrivez-vous dès maintenant pour réserver votre place.",
  },
  {
    id: "news",
    category: "Nouveauté",
    date: "28 janvier 2026",
    title: "Rénovation du Dojo",
    description:
      "Notre espace d'entraînement a été agrandi et modernisé avec de nouveaux tatamis et équipements. Venez découvrir cet espace rénové lors de votre prochaine séance.",
  },
];

const categoryColors: Record<string, string> = {
  event: "text-accent bg-accent/10",
  announcement: "text-foreground bg-secondary",
  news: "text-muted-foreground bg-border/40",
};
---

<section id="news" class="py-24 md:py-32 bg-secondary">
  <div class="mx-auto max-w-6xl px-6">
    <!-- Header -->
    <div class="grid md:grid-cols-2 gap-16 items-end mb-16">
      <div>
        <p class="text-sm tracking-[0.3em] uppercase text-accent mb-4">Actualités</p>
        <h2
          class="font-serif text-3xl md:text-4xl lg:text-5xl font-bold leading-tight text-foreground text-balance"
        >
          Les actualités
        </h2>
      </div>
      <p class="text-base leading-relaxed text-muted-foreground">
        Restez informé des événements à venir, des nouveaux horaires de cours
        et de tout ce qui se passe au dojo, que vous soyez déjà élève ou que
        vous envisagiez de suivre votre premier cours.
      </p>
    </div>

    <!-- Cards -->
    <div class="grid md:grid-cols-3 gap-8">
      {
        news.map((item) => (
          <article class="group flex flex-col border border-border rounded-sm bg-background p-8 transition-colors hover:border-accent/40">
            <div class="flex items-center justify-between mb-6">
              <span
                class={`text-xs font-medium tracking-[0.15em] uppercase px-2.5 py-1 rounded-sm ${categoryColors[item.id]}`}
              >
                {item.category}
              </span>
              <time class="text-xs text-muted-foreground">{item.date}</time>
            </div>
            <h3 class="text-lg font-bold text-foreground leading-snug mb-3">
              {item.title}
            </h3>
            <p class="text-sm leading-relaxed text-muted-foreground flex-1">
              {item.description}
            </p>
          </article>
        ))
      }
    </div>
  </div>
</section>
