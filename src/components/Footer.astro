---
const navLinks = [
  { label: "Philosophie", href: "#philosophy" },
  { label: "Cours", href: "#disciplines" },
  { label: "Votre professeure", href: "#instructor" },
  { label: "Témoignages", href: "#testimonials" },
  { label: "Contact", href: "#contact" },
];
---

<footer class="bg-primary py-16">
  <div class="mx-auto max-w-6xl px-6">
    <div class="grid md:grid-cols-3 gap-12">
      <!-- Brand -->
      <div>
        <span class="text-xl font-bold tracking-wide text-primary-foreground"
          >TAÏSO</span
        >
        <span
          class="text-xs tracking-[0.3em] uppercase text-primary-foreground/50 ml-3"
          >Dojo</span
        >
        <p
          class="text-sm leading-relaxed text-primary-foreground/60 mt-4 max-w-xs"
        >
          Cours particuliers d'arts martiaux ancrés dans la tradition japonaise
          du conditionnement physique et des mouvements conscients.
        </p>
      </div>

      <!-- Quick links -->
      <div>
        <p
          class="text-xs tracking-[0.2em] uppercase text-primary-foreground/40 mb-4"
        >
          Navigation
        </p>
        <ul class="flex flex-col gap-3">
          {
            navLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-primary-foreground/60 hover:text-primary-foreground transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Info -->
      <div>
        <p
          class="text-xs tracking-[0.2em] uppercase text-primary-foreground/40 mb-4"
        >
          Restons en contact
        </p>
        <div class="flex flex-col gap-3 text-sm text-primary-foreground/60">
          <p>69005 Lyon</p>
          <p>contact@taiso-dojo.com</p>
          <p>Lundi – Samedi, 7:00 – 20:00</p>
        </div>
      </div>
    </div>

    <div
      class="border-t border-primary-foreground/10 mt-12 pt-8 flex flex-col md:flex-row items-center justify-between gap-4"
    >
      <p class="text-xs text-primary-foreground/40">
        © 2026 Taïso Dojo. Tous droits réservés.
      </p>
      <p class="text-xs text-primary-foreground/30">
        Un voyage de mille kilomètres commence par un premier pas.
      </p>
    </div>
  </div>
</footer>
