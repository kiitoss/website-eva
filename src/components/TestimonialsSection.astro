---
const testimonials = [
  {
    quote:
      "Taiso has transformed my understanding of movement. Each session leaves me feeling centered, stronger, and deeply connected to my body.",
    name: "Marie L.",
    role: "Practicing for 3 years",
  },
  {
    quote:
      "As a former athlete, I thought I understood physical conditioning. Taiso showed me a whole new dimension of body awareness and control.",
    name: "Thomas D.",
    role: "Practicing for 1 year",
  },
  {
    quote:
      "The personal attention is extraordinary. Every lesson is tailored perfectly to my progress and goals. I have never felt more flexible or at peace.",
    name: "Sophie R.",
    role: "Practicing for 5 years",
  },
]
---

<section id="testimonials" class="py-24 md:py-32 bg-primary text-primary-foreground">
  <div class="mx-auto max-w-6xl px-6">
    <div class="text-center mb-16">
      <p class="text-sm font-medium uppercase tracking-[0.2em] text-primary-foreground/60 mb-3">
        Testimonials
      </p>
      <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl font-bold leading-tight text-balance">
        Words from the Dojo
      </h2>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      {testimonials.map((testimonial) => (
        <div class="rounded-lg border border-primary-foreground/10 bg-primary-foreground/5 p-8 flex flex-col">
          <!-- Stars -->
          <div class="flex gap-1">
            {Array.from({ length: 5 }).map(() => (
              <svg class="h-4 w-4 fill-accent text-accent" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            ))}
          </div>
          <blockquote class="mt-4 text-base leading-relaxed text-primary-foreground/90 flex-1">
            "{testimonial.quote}"
          </blockquote>
          <div class="mt-6">
            <p class="font-semibold text-primary-foreground">{testimonial.name}</p>
            <p class="text-sm text-primary-foreground/60 mt-1">{testimonial.role}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
