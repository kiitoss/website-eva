---
import { cn } from "@/lib/utils"
import { Button } from "@/components/ui/button"
import { Input } from "@/components/ui/input"
import { Label } from "@/components/ui/label"
import { Textarea } from "@/components/ui/textarea"

const inputClass = cn(
  "rounded-sm bg-background px-4 py-3 h-auto border-border",
  "focus-visible:ring-1 focus-visible:ring-accent focus-visible:border-accent"
)

const labelClass = "text-xs tracking-[0.2em] uppercase text-muted-foreground font-normal"
---

<section id="contact" class="py-24 md:py-32 bg-secondary">
  <div class="mx-auto max-w-6xl px-6">
    <div class="grid md:grid-cols-2 gap-16">
      <!-- Left column -->
      <div>
        <p class="text-sm font-medium uppercase tracking-[0.2em] text-accent mb-3">
          Contact
        </p>
        <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl font-bold leading-tight text-foreground text-balance">
          Begin Your Journey
        </h2>
        <p class="mt-6 text-base leading-relaxed text-muted-foreground max-w-md">
          Whether you are new to martial arts or an experienced practitioner, your path to deeper body awareness starts with a single step. Reach out to schedule your first personal lesson.
        </p>

        <div class="mt-10 flex flex-col gap-6">
          <!-- Location -->
          <div class="flex items-start gap-4">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-md bg-accent/10 text-accent">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <div>
              <p class="font-semibold text-foreground">Location</p>
              <p class="text-sm text-muted-foreground">12 Rue de la Paix, 75002 Paris</p>
            </div>
          </div>
          <!-- Phone -->
          <div class="flex items-start gap-4">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-md bg-accent/10 text-accent">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.41 2 2 0 0 1 3.6 1.22h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.78a16 16 0 0 0 6.29 6.29l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92Z"/>
              </svg>
            </div>
            <div>
              <p class="font-semibold text-foreground">Phone</p>
              <p class="text-sm text-muted-foreground">+33 1 42 60 XX XX</p>
            </div>
          </div>
          <!-- Email -->
          <div class="flex items-start gap-4">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-md bg-accent/10 text-accent">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect width="20" height="16" x="2" y="4" rx="2"/>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
              </svg>
            </div>
            <div>
              <p class="font-semibold text-foreground">Email</p>
              <p class="text-sm text-muted-foreground">contact@taiso-dojo.com</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Right column - Form card -->
      <div class="rounded-lg border border-border bg-card p-8 shadow-sm">
        <!-- Success state (hidden by default) -->
        <div id="contact-success" class="hidden flex flex-col items-center justify-center py-12 text-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
            <path d="m9 11 3 3L22 4"/>
          </svg>
          <h3 class="font-serif mt-4 text-2xl font-bold text-card-foreground">Thank You!</h3>
          <p class="text-muted-foreground mt-2">
            Your message has been received. We will be in touch shortly to arrange your first session.
          </p>
        </div>

        <!-- Form -->
        <form id="contact-form" class="flex flex-col gap-5">
          <div class="grid sm:grid-cols-2 gap-5">
            <div class="flex flex-col gap-2">
              <Label htmlFor="firstName" className={labelClass}>First Name</Label>
              <Input id="firstName" name="firstName" type="text" required placeholder="Your first name" className={inputClass} />
            </div>
            <div class="flex flex-col gap-2">
              <Label htmlFor="lastName" className={labelClass}>Last Name</Label>
              <Input id="lastName" name="lastName" type="text" required placeholder="Your last name" className={inputClass} />
            </div>
          </div>

          <div class="flex flex-col gap-2">
            <Label htmlFor="email" className={labelClass}>Email</Label>
            <Input id="email" name="email" type="email" required placeholder="your@email.com" className={inputClass} />
          </div>

          <div class="flex flex-col gap-2">
            <Label htmlFor="phone" className={labelClass}>Phone</Label>
            <Input id="phone" name="phone" type="tel" placeholder="+33 1 XX XX XX XX" className={inputClass} />
          </div>

          <div class="flex flex-col gap-2">
            <label for="experience" class="text-xs tracking-[0.2em] uppercase text-muted-foreground">
              Experience Level
            </label>
            <select
              id="experience"
              name="experience"
              class="flex h-10 w-full rounded-md border border-border bg-background px-3 py-2 text-sm text-foreground focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-accent transition-colors"
            >
              <option value="" disabled selected>Select your level</option>
              <option value="beginner">Complete Beginner</option>
              <option value="some">Some Martial Arts Experience</option>
              <option value="experienced">Experienced Practitioner</option>
            </select>
          </div>

          <div class="flex flex-col gap-2">
            <Label htmlFor="message" className={labelClass}>Message (Optional)</Label>
            <Textarea
              id="message"
              name="message"
              rows={3}
              placeholder="Tell us about your goals and what brings you to Taiso..."
              className={cn(inputClass, "resize-none field-sizing-fixed")}
            />
          </div>

          <Button
            type="submit"
            className="mt-2 rounded-sm h-auto py-3 bg-accent text-accent-foreground hover:bg-accent/90"
          >
            Send Message
          </Button>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form')!
  const success = document.getElementById('contact-success')!

  form.addEventListener('submit', (e) => {
    e.preventDefault()
    form.classList.add('hidden')
    success.classList.remove('hidden')
  })
</script>
