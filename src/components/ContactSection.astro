---
import { cn } from "@/lib/utils";
import { buttonVariants } from "@/components/ui/button";

const ctaClass = cn(
  buttonVariants({ variant: "default" }),
  "rounded-sm px-8 py-3.5 h-auto",
);

const contacts = [
  {
    label: "Adresse",
    value: "69005 Lyon",
    href: "https://maps.app.goo.gl/57pYQn7VEAf2ZJXt5",
    icon: `<path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>`,
  },
  {
    label: "Téléphone",
    value: "+33 1 42 60 XX XX",
    href: "tel:+33142600000",
    icon: `<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.41 2 2 0 0 1 3.6 1.22h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.78a16 16 0 0 0 6.29 6.29l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92Z"/>`,
  },
  {
    label: "Email",
    value: "contact@taiso-dojo.com",
    href: "mailto:contact@taiso-dojo.com",
    icon: `<rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>`,
  },
]
---

<section id="contact" class="py-24 md:py-32 bg-secondary">
  <div class="mx-auto max-w-6xl px-6">
    <!-- Header -->
    <div class="grid md:grid-cols-2 gap-16 items-end mb-16">
      <div>
        <p class="text-sm tracking-[0.3em] uppercase text-accent mb-4">
          Contact
        </p>
        <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl font-bold leading-tight text-foreground text-balance">
          Prendre contact
        </h2>
      </div>
      <p class="text-base leading-relaxed text-muted-foreground">
        Que vous soyez novice en arts martiaux ou pratiquant expérimenté, votre
        chemin vers une conscience corporelle plus profonde commence par un
        simple pas.
      </p>
    </div>

    <!-- Contact info cards -->
    <div class="grid md:grid-cols-3 gap-8">
      {contacts.map((item) => (
        <a
          href={item.href}
          class="group flex flex-col gap-4 border border-border rounded-sm p-8 transition-colors hover:bg-background"
        >
          <div class="flex h-10 w-10 items-center justify-center rounded-md bg-accent/10 text-accent group-hover:bg-accent group-hover:text-accent-foreground transition-colors">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              set:html={item.icon}
            />
          </div>
          <div>
            <p class="text-xs tracking-[0.2em] uppercase text-muted-foreground mb-1">
              {item.label}
            </p>
            <p class="font-semibold text-foreground">{item.value}</p>
          </div>
        </a>
      ))}
    </div>

    <!-- CTA -->
    <div class="mt-12 flex justify-center">
      <a href="mailto:contact@taiso-dojo.com" class={ctaClass}>
        Contactez moi !
      </a>
    </div>
  </div>
</section>
