---
const stats = [
  { number: "20+", label: "Years of Practice" },
  { number: "500+", label: "Students Guided" },
  { number: "3rd", label: "Dan Black Belt" },
  { number: "15+", label: "Years Teaching" },
]
---

<section id="instructor" class="py-24 md:py-32 bg-background">
  <div class="mx-auto max-w-6xl px-6">
    <div class="grid md:grid-cols-2 gap-12 lg:gap-20 items-center">
      <!-- Image -->
      <div class="relative aspect-[3/4] rounded-sm overflow-hidden">
        <img
          src="/images/instructor.jpg"
          alt="Taiso instructor performing a martial arts pose"
          class="absolute inset-0 w-full h-full object-cover"
        />
      </div>

      <!-- Content -->
      <div>
        <p class="text-sm tracking-[0.3em] uppercase text-accent mb-4">
          Your Instructor
        </p>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold leading-tight text-foreground text-balance">
          A Lifetime Devoted to the Art
        </h2>
        <div class="mt-8 flex flex-col gap-6">
          <p class="text-base leading-relaxed text-muted-foreground">
            With over 20 years of practice and teaching, our sensei brings a deep understanding of traditional Japanese body conditioning to every session. Trained in Tokyo under masters of Judo and classical Budo, they carry forward a lineage of disciplined, mindful movement.
          </p>
          <p class="text-base leading-relaxed text-muted-foreground">
            Every lesson is crafted to meet you where you are—whether you are a complete beginner seeking balance and flexibility, or an experienced martial artist looking to refine your foundation.
          </p>
        </div>

        <!-- Credentials -->
        <div class="grid grid-cols-2 gap-6 mt-10 pt-10 border-t border-border">
          {stats.map((stat) => (
            <div>
              <span class="text-2xl md:text-3xl font-bold text-foreground">
                {stat.number}
              </span>
              <p class="text-sm text-muted-foreground mt-1">
                {stat.label}
              </p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
